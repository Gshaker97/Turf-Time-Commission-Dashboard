# These values come from your self-hosted Supabase instance running on Railway.
# After deploying the Supabase template on Railway, grab them from:
#   - Kong service: the public URL becomes VITE_SUPABASE_URL
#   - Supabase studio / .env: the ANON_KEY value becomes VITE_SUPABASE_ANON_KEY

VITE_SUPABASE_URL=https://your-supabase-kong.up.railway.app
VITE_SUPABASE_ANON_KEY=your-anon-key-here
